# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.

# AWS parent region. Must stay us-west-2 — the Honolulu Local Zone is managed from Oregon.
region = "us-west-2"

# Honolulu Local Zone. Requires a one-time opt-in BEFORE running terraform apply:
#   AWS Console → EC2 → Settings → Zones → us-west-2-hnl-1a → Manage → Enable
# To fall back to a standard Oregon AZ instead, set this to "us-west-2a".
availability_zone = "us-west-2-hnl-1a"

# Name of an EC2 key pair that already exists in us-west-2.
# Create one: AWS Console → EC2 → Key Pairs → Create key pair.
# Download the .pem file and keep it out of version control.
key_name = "your-key-pair-name"

# EC2 instance type. t3.medium is supported in the Honolulu Local Zone and
# gives Minecraft comfortable headroom.
instance_type = "t3.medium"

# Restrict SSH to your IP for better security (e.g. "203.0.113.5/32").
# Leaving as 0.0.0.0/0 allows SSH from anywhere — acceptable for a class
# project but not recommended long-term.
allowed_ssh_cidr = "0.0.0.0/0"

# Minecraft server port. Change only if you have a specific reason to.
minecraft_port = 25565
